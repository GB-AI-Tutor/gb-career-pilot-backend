# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Groq AI
GROQ_API_KEY=your_groq_api_key_here

# Brave Search
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Upstash Redis
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token_here

# JWT Secret (generate with: openssl rand -hex 32)
ACCESS_TOKEN_TIME=3
REFRESH_ACCESS_TOKEN_TIME=30
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here

# Frontend
FRONTEND_URL=http://localhost:5173

# Email Configuration
PROJECT_EMAIL=your_email@example.com
EMAIL_APP_PASSWORD=your_app_password_here
ALGORITHM=HS256

# Email Service APIs (choose one)
RESEND_API_KEY=your_resend_api_key_here
BREVO_API=your_brevo_api_key_here
MAILGUN_API=your_mailgun_api_key_here

# Monitoring (Optional - for Sentry error tracking)
SENTRY_DSN=

# Environment
ENVIRONMENT=development

# Database Configuration (for local development with PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gb_career_db

# Python Configuration
PYTHONUNBUFFERED=1
