# ============================================
# GB Career Pilot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# Database - Supabase (PostgreSQL)
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here_from_supabase_dashboard
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here_from_supabase_dashboard

# ============================================
# AI Services
# ============================================
# Groq AI API Key (for LLaMA 3.3 70B model)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Brave Search API Key (optional - for web search features)
# Get from: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ============================================
# Caching - Upstash Redis
# ============================================
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# ============================================
# Authentication & Security
# ============================================
# JWT Configuration
# Generate secret keys with: openssl rand -hex 32
ACCESS_TOKEN_TIME=3
REFRESH_ACCESS_TOKEN_TIME=30
JWT_SECRET_KEY=your_jwt_secret_key_minimum_32_characters_random_string
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_minimum_32_characters_random_string
ALGORITHM=HS256

# ============================================
# Frontend Configuration
# ============================================
# Your deployed frontend URL (or localhost for development)
FRONTEND_URL=http://localhost:5173

# ============================================
# Email Configuration
# ============================================
# Email sender configuration
PROJECT_EMAIL=your-project-email@example.com
EMAIL_APP_PASSWORD=your_email_app_specific_password

# Email Service APIs (choose one or configure multiple as fallbacks)
# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Brevo (Sendinblue): https://app.brevo.com/settings/keys/api
BREVO_API=your_brevo_api_key_here

# Mailgun: https://app.mailgun.com/settings/api_security
MAILGUN_API=your_mailgun_api_key_here

# ============================================
# Monitoring & Error Tracking (Optional)
# ============================================
# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=
# Environment
ENVIRONMENT=development

# Database Configuration (for local development with PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gb_career_db

# Python Configuration
PYTHONUNBUFFERED=1
